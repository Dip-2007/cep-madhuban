# ==========================================
# Madhuban NGO Website - Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ==========================================

# ==========================================
# ADMIN AUTHENTICATION
# ==========================================
# Admin username for dashboard access
VITE_ADMIN_USERNAME=admin

# Admin password (plain text - ensure this file is not committed)
VITE_ADMIN_PASSWORD=your-secure-password

# ==========================================
# SECURITY SETTINGS
# ==========================================
# Session duration in milliseconds (default: 24 hours)
VITE_SESSION_DURATION=86400000

# Max login attempts before lockout
VITE_MAX_LOGIN_ATTEMPTS=5

# Lockout duration in milliseconds (default: 15 minutes)
VITE_LOCKOUT_DURATION=900000

# ==========================================
# UPLOAD CONFIGURATION
# ==========================================
# Maximum image file size in MB
VITE_MAX_IMAGE_SIZE=10

# Maximum video file size in MB
VITE_MAX_VIDEO_SIZE=50

# ==========================================
# APP CONFIGURATION
# ==========================================
# App environment (development/production)
VITE_APP_ENV=development

# App name
VITE_APP_NAME=Madhuban NGO

# App version
VITE_APP_VERSION=1.0.0

# API URL - uncomment when backend is deployed
# VITE_API_URL=http://localhost:3000
# VITE_API_URL=https://yoursite.com

# ==========================================
# NOTES
# ==========================================
# 1. All VITE_ prefixed variables are exposed to the client-side code
# 2. Never store actual secrets here - use a proper backend for production
# 3. For production, implement proper backend authentication with:
#    - JWT tokens with refresh
#    - Password hashing (bcrypt)
#    - HTTPS only
#    - Secure httpOnly cookies
#    - Database-based user storage
# ==========================================
